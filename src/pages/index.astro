---
import Layout from "../layouts/Layout.astro";

const img = (id: string, w: number, q = 75) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=${w}&q=${q}`;

const HERO_IMG = "1747239202356-764770773c9a"; // pilates reformer, moviment
const PILATES_IMG = "1717500251716-27057c48ace4"; // pilates, estirament assegut al reformer

const WA = "https://wa.me/34664762570?text=Hola%20FisioyM%C3%A9s%2C%20voldria%20demanar%20cita.";
const TEL = "tel:+34664762570";
const MAIL = "mailto:info@fisioymes.com";

// Petit helper d'i18n: converteix {ca, es} en els data-attributes que
// llegeix l'script del selector d'idioma per intercanviar el text.
const tr = (pair: { ca: string; es: string }) => ({ "data-ca-text": pair.ca, "data-es-text": pair.es });

const navLinks = [
  { href: "#tractaments", ca: "Tractaments", es: "Tratamientos" },
  { href: "#equip", ca: "Equip", es: "Equipo" },
  { href: "#clinica", ca: "La Clínica", es: "La Clínica" },
  { href: "#preus", ca: "Preus", es: "Precios" },
  { href: "#opinions", ca: "Opinions", es: "Opiniones" },
  { href: "#contacte", ca: "Contacte", es: "Contacto" },
];
const footLinks = navLinks.filter((l) => l.href !== "#opinions");

const generalList = [
  { ca: "Cervicàlgies", es: "Cervicalgias" },
  { ca: "Dorsàlgies", es: "Dorsalgias" },
  { ca: "Lumbàlgies", es: "Lumbalgias" },
  { ca: "Radiculopaties", es: "Radiculopatías" },
  { ca: "Hèrnies discals", es: "Hernias discales" },
  { ca: "Migranyes i cefalees tensionals", es: "Migrañas y cefaleas tensionales" },
  { ca: "Rigidesa articular", es: "Rigidez articular" },
  { ca: "Tendinopaties", es: "Tendinopatías" },
  { ca: "Sobrecàrregues musculars", es: "Sobrecargas musculares" },
  { ca: "Trencaments musculars", es: "Roturas musculares" },
  { ca: "Limfedema", es: "Linfedema" },
  { ca: "Punts gallet", es: "Puntos gatillo" },
  { ca: "Disfuncions del sòl pelvià", es: "Disfunciones del suelo pélvico" },
  { ca: "ATM", es: "ATM" },
  { ca: "Rehabilitació postquirúrgica", es: "Rehabilitación postquirúrgica" },
];

const otherAreas = [
  {
    t: { ca: "Teràpia manual i tecnologia", es: "Terapia manual y tecnología" },
    d: {
      ca: "Massatge descontracturant, esportiu, relaxant i drenatge limfàtic. Punció seca, electròlisi percutània (EPI), radiofreqüència / tecarteràpia, magnetoteràpia i ultrasons — la tècnica es tria segons el teixit, no a l'inrevés.",
      es: "Masaje descontracturante, deportivo, relajante y drenaje linfático. Punción seca, electrólisis percutánea (EPI), radiofrecuencia / tecarterapia, magnetoterapia y ultrasonidos — la técnica se elige según el tejido, no al revés.",
    },
  },
  {
    t: { ca: "Fisioteràpia esportiva", es: "Fisioterapia deportiva" },
    d: {
      ca: "Readaptació després d'una lesió i prevenció abans que arribi: força, mobilitat i control del gest per tornar a competir o simplement a córrer per Collserola sense por a la recaiguda.",
      es: "Readaptación tras una lesión y prevención antes de que llegue: fuerza, movilidad y control del gesto para volver a competir o simplemente a correr por Collserola sin miedo a la recaída.",
    },
  },
  {
    t: { ca: "Pilates terapèutic i entrenament personal", es: "Pilates terapéutico y entrenamiento personal" },
    d: {
      ca: "Classes reduïdes centrades en control postural i sòl pelvià. La primera classe és de prova i no es cobra — així ho comproves abans de decidir.",
      es: "Clases reducidas centradas en el control postural y el suelo pélvico. La primera clase es de prueba y no se cobra — así lo compruebas antes de decidir.",
    },
  },
];

const team = [
  { name: "Rodrigo Evangelisti", role: { ca: "Fisioteràpia esportiva i invasiva, fisioestètica i readaptació esportiva.", es: "Fisioterapia deportiva e invasiva, fisioestética y readaptación deportiva." } },
  { name: "Diana", role: { ca: "Fisioterapeuta a l'equip de FisioyMés.", es: "Fisioterapeuta en el equipo de FisioyMés." } },
  { name: "Laia Costa", role: { ca: "Fisioterapeuta a l'equip de FisioyMés.", es: "Fisioterapeuta en el equipo de FisioyMés." } },
];

const testimonials = [
  {
    q: {
      ca: "Vaig arribar amb una fractura de colze i una recuperació que la pròpia traumatòloga donava per llarga. Amb FisioyMés vaig recuperar mobilitat molt abans del que ningú esperava.",
      es: "Llegué con una fractura de codo y una recuperación que la propia traumatóloga daba por larga. Con FisioyMés recuperé movilidad mucho antes de lo que nadie esperaba.",
    },
    a: { ca: "Recuperació postquirúrgica de colze", es: "Recuperación postquirúrgica de codo" },
  },
  {
    q: {
      ca: "Et tracten com a casa: ambient càlid i familiar des del primer dia, però amb un nivell de professionalitat que es nota en cada sessió.",
      es: "Te tratan como en casa: ambiente cálido y familiar desde el primer día, pero con un nivel de profesionalidad que se nota en cada sesión.",
    },
    a: { ca: "Pacient habitual de fisioteràpia general", es: "Paciente habitual de fisioterapia general" },
  },
  {
    q: { ca: "Com FisioyMés no n'hi ha cap altre a Sant Cugat.", es: "Como FisioyMés no hay ningún otro en Sant Cugat." },
    a: { ca: "Ressenya a Google", es: "Reseña en Google" },
  },
];

const prices = [
  { t: { ca: "Sessió de fisioteràpia", es: "Sesión de fisioterapia" }, d: { ca: "30 minuts.", es: "30 minutos." }, p: { ca: "39 €", es: "39 €" } },
  { t: { ca: "Sessió de fisioteràpia", es: "Sesión de fisioterapia" }, d: { ca: "50 minuts.", es: "50 minutos." }, p: { ca: "55 €", es: "55 €" } },
  { t: { ca: "Bo de sessions", es: "Bono de sesiones" }, d: { ca: "3 / 5 / 10 sessions.", es: "3 / 5 / 10 sesiones." }, p: { ca: "-6% / -10% / -15%", es: "-6% / -10% / -15%" } },
  { t: { ca: "Pilates individual", es: "Pilates individual" }, d: { ca: "1 o 2 classes per setmana.", es: "1 o 2 clases por semana." }, p: { ca: "45 € / 70 € classe", es: "45 € / 70 € clase" } },
  { t: { ca: "Pilates en grup", es: "Pilates en grupo" }, d: { ca: "1 o 2 classes per setmana.", es: "1 o 2 clases por semana." }, p: { ca: "60 € / 90 € mes", es: "60 € / 90 € mes" } },
  { t: { ca: "Primera classe de Pilates", es: "Primera clase de Pilates" }, d: { ca: "Perquè el provis sense compromís.", es: "Para que la pruebes sin compromiso." }, p: { ca: "Gratuïta", es: "Gratuita" } },
];

const clinicFacilities = [
  { ca: "Sala de Pilates", es: "Sala de Pilates" },
  { ca: "Gimnàs", es: "Gimnasio" },
  { ca: "Sales de tractament individual", es: "Salas de tratamiento individual" },
];

const i18n = {
  skip: { ca: "Saltar a demanar cita", es: "Saltar a pedir cita" },
  heroPre: { ca: "Fisioteràpia que et torna al", es: "Fisioterapia que te devuelve al" },
  heroEm: { ca: "moviment", es: "movimiento" },
  heroLede: {
    ca: "Tractament personalitzat a Sant Cugat del Vallès: fisioteràpia general i esportiva, massatge terapèutic i pilates. El mateix equip, de la primera visita fins que tornes a fer el que t'agrada.",
    es: "Tratamiento personalizado en Sant Cugat del Vallès: fisioterapia general y deportiva, masaje terapéutico y pilates. El mismo equipo, desde la primera visita hasta que vuelvas a hacer lo que te gusta.",
  },
  heroCta: { ca: "Demana cita per WhatsApp", es: "Pide cita por WhatsApp" },
  heroTrust: { ca: "5,0/5 — 66 ressenyes a Google", es: "5,0/5 — 66 reseñas en Google" },
  treatH: { ca: "Què tractem", es: "Qué tratamos" },
  treatP: {
    ca: "De la primera molèstia a la tornada a l'esport, amb la tècnica que li toca a cada teixit.",
    es: "Desde la primera molestia hasta la vuelta al deporte, con la técnica que le corresponde a cada tejido.",
  },
  treatFeaturedH: { ca: "Fisioteràpia general", es: "Fisioterapia general" },
  photoCaption: { ca: "Pilates terapèutic — primera classe gratuïta.", es: "Pilates terapéutico — primera clase gratuita." },
  teamH: { ca: "Qui et tractarà", es: "Quién te tratará" },
  teamP: {
    ca: "L'ambient càlid i familiar que els pacients destaquen a les ressenyes, sessió rere sessió.",
    es: "El ambiente cálido y familiar que los pacientes destacan en las reseñas, sesión tras sesión.",
  },
  teamMore: { ca: "+ la resta de l'equip de FisioyMés, a Carrer Xerric 4.", es: "+ el resto del equipo de FisioyMés, en Carrer Xerric 4." },
  clinicH: { ca: "La Clínica", es: "La Clínica" },
  clinicText: {
    ca: "Fa més d'una dècada que acompanyem pacients a Sant Cugat del Vallès combinant l'experiència acumulada amb tècniques actualitzades. Cada tractament s'adapta a la persona — no a l'inrevés — perquè la recuperació sigui eficaç i es noti des de la primera visita.",
    es: "Llevamos más de una década acompañando a pacientes en Sant Cugat del Vallès combinando la experiencia acumulada con técnicas actualizadas. Cada tratamiento se adapta a la persona — no al revés — para que la recuperación sea eficaz y se note desde la primera visita.",
  },
  reviewsCount: { ca: "66 ressenyes a Google", es: "66 reseñas en Google" },
  reviewsSr: { ca: "Opinions dels pacients", es: "Opiniones de los pacientes" },
  pricesH: { ca: "Preus", es: "Precios" },
  pricesPre: { ca: "Les nostres tarifes, clares des del primer dia. ", es: "Nuestras tarifas, claras desde el primer día. " },
  pricesStrong: { ca: "Descomptes per bo de sessions", es: "Descuentos por bono de sesiones" },
  pricesPost: { ca: " si fas seguiment continuat.", es: " si haces seguimiento continuado." },
  contactH: { ca: "Demana la teva cita.", es: "Pide tu cita." },
  contactLede: { ca: "Escriu-nos per WhatsApp i et diem quan tenim hora disponible.", es: "Escríbenos por WhatsApp y te decimos cuándo tenemos hora disponible." },
  contactWaBtn: { ca: "Escriu-nos per WhatsApp", es: "Escríbenos por WhatsApp" },
  orDivider: { ca: "o", es: "o" },
  formName: { ca: "Nom", es: "Nombre" },
  formEmail: { ca: "Email", es: "Email" },
  formMsg: { ca: "Missatge", es: "Mensaje" },
  formSend: { ca: "Enviar", es: "Enviar" },
  addrLabel: { ca: "Adreça", es: "Dirección" },
  hoursLabel: { ca: "Horari", es: "Horario" },
  phoneLabel: { ca: "Telèfon", es: "Teléfono" },
  emailLabel: { ca: "Email", es: "Email" },
  hoursValue: { ca: "Dl–Dj 9–21 h · Dv 9–20 h · Ds 10–14 h", es: "Lu–Ju 9–21 h · Vi 9–20 h · Sá 10–14 h" },
  footTag: { ca: "Fisioteràpia a Sant Cugat del Vallès. 5,0★ sobre 66 ressenyes a Google.", es: "Fisioterapia en Sant Cugat del Vallès. 5,0★ sobre 66 reseñas en Google." },
  footDemo: { ca: "Pàgina de demostració a mida — no és el lloc web oficial.", es: "Página de demostración a medida — no es el sitio web oficial." },
};
---

<Layout>
  <a class="skip" href="#contacte" {...tr(i18n.skip)}>{i18n.skip.ca}</a>

  <header class="nav" data-nav>
    <div class="wrap nav__row">
      <a class="brand" href="#top" aria-label="FisioyMés, inici">
        <span class="brand__mark" aria-hidden="true"></span>
        <span class="brand__word">FisioyMés</span>
      </a>
      <nav class="nav__links" id="primary-nav" aria-label="Principal">
        {navLinks.map((l) => <a href={l.href} data-ca-text={l.ca} data-es-text={l.es}>{l.ca}</a>)}
        <div class="lang-toggle" role="group" aria-label="Idioma">
          <button type="button" class="lang-btn" data-lang-btn="ca" aria-pressed="true">CA</button>
          <button type="button" class="lang-btn" data-lang-btn="es" aria-pressed="false">ES</button>
        </div>
      </nav>
      <button class="nav__toggle" type="button" data-nav-toggle aria-expanded="false" aria-controls="primary-nav" aria-label="Obrir el menú">
        <span class="nav__toggle-bar" aria-hidden="true"></span>
      </button>
      <a class="btn btn--solid nav__cta" href={WA} target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.7 14.2c-.2.6-1.4 1.2-2 1.3-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5.1-4.5-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5.2.6.8 2 .9 2.1.1.2.1.4 0 .6-.4.8-.8.8-.5 1.3.9 1.7 1.8 2.3 3.2 3 .2.1.4.1.5-.1.2-.2.7-.8.9-1.1.2-.3.4-.2.6-.1l1.9.9c.2.1.4.2.5.3.1.2.1.9-.1 1.4Z"/></svg>
        WhatsApp
      </a>
    </div>
  </header>

  <main id="top">
    <!-- ░░ HERO ░░ -->
    <section class="hero" aria-labelledby="hero-title">
      <img class="hero__img" src={img(HERO_IMG, 2000, 68)}
        srcset={`${img(HERO_IMG, 1100, 65)} 1100w, ${img(HERO_IMG, 1700, 68)} 1700w, ${img(HERO_IMG, 2400, 68)} 2400w`}
        sizes="100vw"
        alt="Dona fent un exercici de pilates sobre un reformer, en ple moviment controlat." fetchpriority="high" />
      <div class="hero__veil"></div>

      <svg class="hero__motif" viewBox="0 0 600 160" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,90 L18,45 L36,128 L54,35 L72,115 L90,55 L108,100 L126,65
                 C158,85 188,42 220,82
                 C262,124 296,40 338,82
                 C388,124 430,40 480,82
                 C522,112 562,50 600,82" />
      </svg>

      <div class="wrap hero__inner">
        <h1 id="hero-title" class="hero__title">
          <span {...tr(i18n.heroPre)}>{i18n.heroPre.ca}</span> <em {...tr(i18n.heroEm)}>{i18n.heroEm.ca}</em>.
        </h1>
        <p class="hero__lede" {...tr(i18n.heroLede)}>{i18n.heroLede.ca}</p>
        <div class="hero__actions">
          <a class="btn btn--solid" href={WA} target="_blank" rel="noopener" {...tr(i18n.heroCta)}>{i18n.heroCta.ca}</a>
          <a class="btn btn--ghost" href={TEL}>664 76 25 70</a>
        </div>
        <p class="hero__trust"><span class="hero__stars" aria-hidden="true">★★★★★</span> <span {...tr(i18n.heroTrust)}>{i18n.heroTrust.ca}</span></p>
      </div>
    </section>

    <span class="wavemark" aria-hidden="true"></span>

    <!-- ░░ TRACTAMENTS ░░ -->
    <section class="treat" id="tractaments" aria-labelledby="treat-h">
      <div class="wrap">
        <header class="sec-head" data-reveal>
          <h2 id="treat-h" {...tr(i18n.treatH)}>{i18n.treatH.ca}</h2>
          <p {...tr(i18n.treatP)}>{i18n.treatP.ca}</p>
        </header>

        <div class="treat__featured" data-reveal>
          <h3 {...tr(i18n.treatFeaturedH)}>{i18n.treatFeaturedH.ca}</h3>
          <ul class="treat__pills">
            {generalList.map((item) => <li {...tr(item)}>{item.ca}</li>)}
          </ul>
        </div>

        <ul class="treat__list">
          {otherAreas.map((area) => (
            <li data-reveal>
              <span class="treat__mark" aria-hidden="true"></span>
              <div>
                <h3 {...tr(area.t)}>{area.t.ca}</h3>
                <p {...tr(area.d)}>{area.d.ca}</p>
              </div>
            </li>
          ))}
        </ul>

        <figure class="treat__photo" data-reveal>
          <img src={img(PILATES_IMG, 1400)} srcset={`${img(PILATES_IMG, 800)} 800w, ${img(PILATES_IMG, 1400)} 1400w`} sizes="(max-width: 800px) 100vw, 640px" alt="Exercici de pilates terapèutic sobre reformer, treballant control i estirament." loading="lazy" />
          <figcaption {...tr(i18n.photoCaption)}>{i18n.photoCaption.ca}</figcaption>
        </figure>
      </div>
    </section>

    <!-- ░░ EQUIP ░░ -->
    <section class="team" id="equip" aria-labelledby="team-h">
      <div class="wrap">
        <header class="sec-head sec-head--light" data-reveal>
          <h2 id="team-h" {...tr(i18n.teamH)}>{i18n.teamH.ca}</h2>
          <p {...tr(i18n.teamP)}>{i18n.teamP.ca}</p>
        </header>
        <ul class="team__list">
          {team.map((p) => (
            <li data-reveal>
              <span class="team__avatar" aria-hidden="true">{p.name.slice(0, 1)}</span>
              <div>
                <h3>{p.name}</h3>
                <p {...tr(p.role)}>{p.role.ca}</p>
              </div>
            </li>
          ))}
        </ul>
        <p class="team__more" data-reveal {...tr(i18n.teamMore)}>{i18n.teamMore.ca}</p>
      </div>
    </section>

    <!-- ░░ LA CLÍNICA ░░ -->
    <section class="clinic" id="clinica" aria-labelledby="clinica-h">
      <div class="wrap wrap--narrow" data-reveal>
        <h2 id="clinica-h" {...tr(i18n.clinicH)}>{i18n.clinicH.ca}</h2>
        <p class="clinic__text" {...tr(i18n.clinicText)}>{i18n.clinicText.ca}</p>
        <ul class="treat__pills clinic__facilities">
          {clinicFacilities.map((f) => <li {...tr(f)}>{f.ca}</li>)}
        </ul>
      </div>
    </section>

    <!-- ░░ OPINIONS ░░ -->
    <section class="reviews" id="opinions" aria-labelledby="reviews-h">
      <div class="wrap">
        <div class="reviews__stat" data-reveal>
          <p class="reviews__score">5,0</p>
          <div>
            <span class="hero__stars" aria-hidden="true">★★★★★</span>
            <p {...tr(i18n.reviewsCount)}>{i18n.reviewsCount.ca}</p>
          </div>
        </div>
        <h2 id="reviews-h" class="sr-only" {...tr(i18n.reviewsSr)}>{i18n.reviewsSr.ca}</h2>
        <ul class="reviews__list">
          {testimonials.map((t) => (
            <li data-reveal>
              <p class="reviews__q">&ldquo;<span {...tr(t.q)}>{t.q.ca}</span>&rdquo;</p>
              <p class="reviews__a" {...tr(t.a)}>{t.a.ca}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <span class="wavemark" aria-hidden="true"></span>

    <!-- ░░ PREUS ░░ -->
    <section class="prices" id="preus" aria-labelledby="prices-h">
      <div class="wrap">
        <header class="sec-head" data-reveal>
          <h2 id="prices-h" {...tr(i18n.pricesH)}>{i18n.pricesH.ca}</h2>
          <p><span {...tr(i18n.pricesPre)}>{i18n.pricesPre.ca}</span><strong {...tr(i18n.pricesStrong)}>{i18n.pricesStrong.ca}</strong><span {...tr(i18n.pricesPost)}>{i18n.pricesPost.ca}</span></p>
        </header>
        <ul class="price-list">
          {prices.map((row) => (
            <li data-reveal>
              <div>
                <h3 {...tr(row.t)}>{row.t.ca}</h3>
                <p {...tr(row.d)}>{row.d.ca}</p>
              </div>
              <span class="price-list__p" {...tr(row.p)}>{row.p.ca}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ░░ CONTACTE ░░ -->
    <section class="contact" id="contacte" aria-labelledby="contact-h">
      <div class="wrap contact__grid">
        <div class="contact__intro" data-reveal>
          <h2 id="contact-h" {...tr(i18n.contactH)}>{i18n.contactH.ca}</h2>
          <p class="contact__lede" {...tr(i18n.contactLede)}>{i18n.contactLede.ca}</p>
          <a class="btn btn--solid contact__wa" href={WA} target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.7 14.2c-.2.6-1.4 1.2-2 1.3-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5.1-4.5-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5.2.6.8 2 .9 2.1.1.2.1.4 0 .6-.4.8-.8.8-.5 1.3.9 1.7 1.8 2.3 3.2 3 .2.1.4.1.5-.1.2-.2.7-.8.9-1.1.2-.3.4-.2.6-.1l1.9.9c.2.1.4.2.5.3.1.2.1.9-.1 1.4Z"/></svg>
            <span {...tr(i18n.contactWaBtn)}>{i18n.contactWaBtn.ca}</span>
          </a>

          <div class="contact__divider" role="separator"><span {...tr(i18n.orDivider)}>{i18n.orDivider.ca}</span></div>

          <form class="contact__form" data-contact-form novalidate>
            <div class="field">
              <label for="cf-name" {...tr(i18n.formName)}>{i18n.formName.ca}</label>
              <input id="cf-name" name="name" type="text" autocomplete="name" required />
            </div>
            <div class="field">
              <label for="cf-email" {...tr(i18n.formEmail)}>{i18n.formEmail.ca}</label>
              <input id="cf-email" name="email" type="email" autocomplete="email" required />
            </div>
            <div class="field">
              <label for="cf-msg" {...tr(i18n.formMsg)}>{i18n.formMsg.ca}</label>
